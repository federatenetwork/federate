# Environment for federate-dnsd / federate-gatewayd systemd units.
# Copy to /etc/federate/node.env, edit, then: chmod 600 /etc/federate/node.env
#
# The public IPv4 of THIS box. The directory rejects registrations whose
# health endpoint is not one of the node's declared IPs (anti-SSRF), so this
# must be the real address.
PUBLIC_IP=x.x.x.x

# The Federate Root public key (hex). REQUIRED in production: without it the
# node pins whatever key the first fetched zone advertises (TOFU).
# Get it from the operator, or on Node 1: curl -s https://federate.network/v1/status
ROOT_KEY=replace-with-federate-root-public-key-hex

# Free-form region label used for provider ranking, e.g. de-fsn, br-sp.
REGION=de-fsn
